# DeepSeek-compatible model API configuration.
# Do not commit real secrets in .env.

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/chat/completions
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_THINKING=disabled
DEEPSEEK_REASONING_EFFORT=
DEEPSEEK_MAX_TOKENS=12000
DEEPSEEK_TEMPERATURE=0.0

# Generic placeholder for future adapters or alternate runners.
MODEL_API_KEY=

# Optional override for the dashboard/API summary files.
TRACEGATE_RESULTS_DIR=results
